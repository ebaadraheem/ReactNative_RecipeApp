{
  "cli": {
    "version": ">= 12.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "SERVER_URL": "https://localhost:7071"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "SERVER_URL": "https://localhost:7071"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "SERVER_URL": "@SERVER_URL"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
